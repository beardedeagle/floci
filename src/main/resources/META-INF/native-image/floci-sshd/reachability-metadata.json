    { "type": "java.security.KeyPairGenerator", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
