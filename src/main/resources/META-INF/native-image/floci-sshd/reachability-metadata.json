{
  "comment": "Native-image metadata for Apache MINA sshd (AWS Transfer connector SFTP client, SftpConnectorClient). MINA: (a) builds JDK dynamic proxies for its event-listener interfaces; (b) loads its NIO IO factory reflectively by name (Nio2ServiceFactoryFactory); (c) builds JCA SecurityEntityFactory wrappers by reflectively locating getInstance(...) on the JCA entity classes. SftpConnectorClient sets org.apache.sshd.security.registrars=none, so MINA loads NO third-party security-provider registrar -- every algorithm resolves through the JDK default providers (SunEC/SunRsaSign/SunJCE) via plain getInstance(...), which is why the JCA entity classes below are registered for reflective getInstance lookup. This is distribution-agnostic (CE/Mandrel/Temurin) and avoids the JCE jar-signature check that breaks BouncyCastle-by-name in a native image. The BouncyCastleSecurityProviderRegistrar entry is retained defensively and is inert while registrars=none.",
  "reflection": [
    { "type": { "proxy": ["org.apache.sshd.common.forward.PortForwardingEventListener"] } },
    { "type": { "proxy": ["org.apache.sshd.common.session.SessionListener"] } },
    { "type": { "proxy": ["org.apache.sshd.common.channel.ChannelListener"] } },
    { "type": "org.apache.sshd.common.util.security.bouncycastle.BouncyCastleSecurityProviderRegistrar", "allDeclaredConstructors": true },
    { "type": "org.apache.sshd.common.io.nio2.Nio2ServiceFactoryFactory", "allDeclaredConstructors": true },
    { "type": "java.security.AlgorithmParameters", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "java.security.KeyFactory", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "java.security.KeyPairGenerator", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "java.security.Signature", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "java.security.MessageDigest", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "java.security.cert.CertificateFactory", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "javax.crypto.Cipher", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "javax.crypto.Mac", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] },
    { "type": "javax.crypto.KeyAgreement", "methods": [ {"name":"getInstance","parameterTypes":["java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.lang.String"]}, {"name":"getInstance","parameterTypes":["java.lang.String","java.security.Provider"]} ] }
  ]
}
